PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://paradiso:password@localhost:5432/paradiso
# Oppure singoli parametri:
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=paradiso
# PG_PASSWORD=password
# PG_DATABASE=paradiso

# JWT (cambia in produzione)
JWT_SECRET=cambia-con-una-chiave-sicura-in-produzione
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (per CORS)
FRONTEND_URL=http://localhost:3000
